# Copy this to .env and fill in real values. .env is git-ignored.

# ElevenLabs (Voiceover)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Pexels (Stock Video, free tier with API key)
PEXELS_API_KEY=your_pexels_key_here

# Lemon Squeezy (Pay-to-Remove Watermark)
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_key_here
LEMONSQUEEZY_STORE_SUBDOMAIN=your_store_subdomain
LEMONSQUEEZY_PRODUCT_REMOVE_WATERMARK=
LEMONSQUEEZY_PRODUCT_PRO_MONTHLY=
