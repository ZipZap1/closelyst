# Copy this to .env and fill in real values. .env is git-ignored.

# ElevenLabs (Voiceover)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Pexels (Stock Video, free tier with API key)
PEXELS_API_KEY=your_pexels_key_here

# Lemon Squeezy (Pay-to-Remove Watermark)
LEMONSQUEEZY_API_KEY=your_lemonsqueezy_key_here
LEMONSQUEEZY_STORE_SUBDOMAIN=your_store_subdomain
LEMONSQUEEZY_PRODUCT_REMOVE_WATERMARK=
LEMONSQUEEZY_PRODUCT_PRO_MONTHLY=

# Replicate (AI image generation + enhancement, Pro features only)
# Sign up: https://replicate.com -> Profile -> API Tokens -> Create token
# Pricing: pay-as-you-go, ~3ct per image (Flux Schnell), ~1ct per enhance
REPLICATE_API_TOKEN=your_replicate_token_here

# Optional: Demo video URL and ProductHunt link. Both render in the app
# header when set. Leave empty until you have a recorded demo / a PH page.
DEMO_VIDEO_URL=
PRODUCTHUNT_URL=

# Optional: sync.so (premium lip-sync). When set, the lip-sync mode uses
# sync.so /v2/generate (lipsync-2 model) instead of Replicate's LatentSync.
# Get a key at https://sync.so -> Settings -> API Keys.
SYNC_API_KEY=
