# Copy this to .env and fill in real values. .env is git-ignored.

# ElevenLabs (Voiceover, default TTS backend)
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# OpenAI (Voiceover, alternative TTS backend fuer score_voices.py / run_voice_test.py)
# Only needed for the voice-quality test runner and free-tier voice picker.
OPENAI_API_KEY=your_openai_key_here

# Pexels (Stock Video, free tier with API key)
PEXELS_API_KEY=your_pexels_key_here

# Polar (Pay-to-Remove Watermark and Pro Subscription)
# Get API token: polar.sh -> Settings -> Developers -> Create token
# Checkout URLs: Products -> [product] -> Checkout Links -> copy URL
POLAR_API_TOKEN=your_polar_token_here
POLAR_CHECKOUT_URL_REMOVE_WATERMARK=
POLAR_CHECKOUT_URL_PRO_MONTHLY=

# Master License Key (intern, fuer Owner/Demo, umgeht Polar komplett)
# Generieren mit: python3 -c "import secrets; print('VC-MASTER-' + secrets.token_urlsafe(24))"
# Wer diesen Key im License-Feld eingibt, kriegt Pro-Equivalent (unlimited).
# Niemals teilen, niemals committen. Mindestens 16 Zeichen lang.
MASTER_LICENSE_KEY=

# Replicate (AI image generation + enhancement, Pro features only)
# Sign up: https://replicate.com -> Profile -> API Tokens -> Create token
# Pricing: pay-as-you-go, ~3ct per image (Flux Schnell), ~1ct per enhance
REPLICATE_API_TOKEN=your_replicate_token_here

# Optional: Demo video URL and ProductHunt link. Both render in the app
# header when set. Leave empty until you have a recorded demo / a PH page.
DEMO_VIDEO_URL=
PRODUCTHUNT_URL=

# Optional: sync.so (premium lip-sync). When set, the lip-sync mode uses
# sync.so /v2/generate (lipsync-2 model) instead of Replicate's LatentSync.
# Get a key at https://sync.so -> Settings -> API Keys.
SYNC_API_KEY=

# Supabase (free-tier daily rate limiting)
# Sign up: https://supabase.com -> New project
# URL:     Settings -> API -> Project URL
# Key:     Settings -> API -> service_role secret (NOT anon, anon is too restricted)
# Run the SQL in BUILD.md's "Supabase setup" section to create the table + RPC.
SUPABASE_URL=
SUPABASE_KEY=
